{
	"dependencies": {
		"git-state": "^4.1.0"
	},
	"devDependencies": {
		"@pkgs/env": "workspace:*",
		"@pkgs/ts-config": "workspace:*",
		"@pkgs/types": "workspace:*",
		"@types/git-state": "^4.1.3"
	},
	"main": "dist/index.js",
	"name": "client",
