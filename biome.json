{
    "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "assists": {
        "enabled": true,
        "actions": {
            "source": {
                "useSortedKeys": "on"
            }
        }
    },
    "files": {
        "ignoreUnknown": true,
        "ignore": [
            "commitlint.config.js"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "tab",
        "useEditorconfig": true
    },
    "organizeImports": {
        "enabled": true
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedVariables": "error",
                "noUnusedImports": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "none",
            "quoteProperties": "asNeeded"
        },
        "assists": {
            "enabled": true
        }
    },
    "json": {
        "formatter": {
            "enabled": true,
            "trailingCommas": "none"
        }
    }
}
