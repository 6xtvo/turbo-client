{
	"$schema": "https://turborepo.com/schema.json",
	"globalDependencies": [".env", ".env.local"],
	"remoteCache": {
		"enabled": true
	},
	"tasks": {
		"biome": {
			"dependsOn": ["biome"]
		},
		"build": {
			"cache": true,
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "logs/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["^dev"]
		},
		"start": {
			"dependsOn": ["^start"]
		}
	},
	"ui": "tui"
}
